---
import Layout from '../layouts/main.astro';
import { getCollection } from 'astro:content';
import { ArrowRight, Calendar, Check, Clock, Copy } from 'lucide-react';
import { withBase } from '@/lib/utils';
import { Hero } from '@/components/Hero';
import { Features } from '@/components/Features';
import { FAQ } from '@/components/FAQ';
import { estimateReadingTime } from '@/lib/readingTime';

const sortByPubDateDesc = (a: { data: { pubDate: Date } }, b: { data: { pubDate: Date } }) =>
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf();

const getLatestPosts = async (collection: 'blog' | 'news') => {
  return (await getCollection(collection, ({ data }) => !data.draft))
    .sort(sortByPubDateDesc)
    .slice(0, 3);
};

const latestBlogPosts = await getLatestPosts('blog');
const latestNewsPosts = await getLatestPosts('news');

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });

const panelCardClass =
  "relative isolate rounded-2xl bg-gradient-to-b from-card via-card/95 to-card/85 dark:from-card dark:via-card dark:to-card/75 p-6 md:p-8 ring-1 ring-black/5 dark:ring-white/10 transition-all duration-300 shadow-[inset_0_1px_0_hsl(var(--background)/0.75),0_14px_32px_-24px_rgba(2,8,23,0.6)] dark:shadow-[inset_0_1px_0_rgba(255,255,255,0.08),0_18px_38px_-24px_rgba(0,0,0,0.9)] before:pointer-events-none before:absolute before:-inset-2 before:-z-10 before:rounded-[1.15rem] before:border before:border-slate-300/70 before:opacity-90 before:blur-lg dark:before:border-slate-600/60 dark:before:opacity-80 after:pointer-events-none after:absolute after:-inset-6 after:-z-20 after:rounded-[1.7rem] after:bg-slate-300/35 after:opacity-70 after:blur-3xl dark:after:bg-slate-900/70 dark:after:opacity-80";
---

<Layout title="AI Colleagues - Build Reliable AI Systems">
  <Hero client:load />
  <section class="py-12 border-b bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-4xl rounded-2xl border bg-background/80 p-6 shadow-sm">
        <p class="text-sm font-medium text-muted-foreground">Install Orcheo</p>
        <div class="mt-3 space-y-3" data-install-tabs>
          <div class="flex flex-wrap gap-2" role="tablist" aria-label="Installation paths">
            <button
              type="button"
              role="tab"
              id="install-tab-macos"
              class="rounded-md border bg-background px-3 py-1.5 text-xs font-medium transition-colors hover:bg-muted"
              data-install-tab-trigger
              data-tab-id="install-macos"
              aria-controls="install-panel-macos"
              aria-selected="true"
              tabindex="0"
            >
              macOS/Linux
            </button>
            <button
              type="button"
              role="tab"
              id="install-tab-windows"
              class="rounded-md border bg-background px-3 py-1.5 text-xs font-medium transition-colors hover:bg-muted"
              data-install-tab-trigger
              data-tab-id="install-windows"
              aria-controls="install-panel-windows"
              aria-selected="false"
              tabindex="-1"
            >
              Windows (Powershell)
            </button>
            <button
              type="button"
              role="tab"
              id="install-tab-sdk"
              class="rounded-md border bg-background px-3 py-1.5 text-xs font-medium transition-colors hover:bg-muted"
              data-install-tab-trigger
              data-tab-id="install-sdk"
              aria-controls="install-panel-sdk"
              aria-selected="false"
              tabindex="-1"
            >
              SDK
            </button>
            <button
              type="button"
              role="tab"
              id="install-tab-upgrade"
              class="rounded-md border bg-background px-3 py-1.5 text-xs font-medium transition-colors hover:bg-muted"
              data-install-tab-trigger
              data-tab-id="install-upgrade"
              aria-controls="install-panel-upgrade"
              aria-selected="false"
              tabindex="-1"
            >
              Upgrade
            </button>
          </div>
          <div
            class="relative"
            role="tabpanel"
            id="install-panel-macos"
            aria-labelledby="install-tab-macos"
            tabindex="0"
            data-install-tab-panel
            data-tab-id="install-macos"
          >
            <button
              type="button"
              aria-label="Copy command"
              class="absolute right-2 top-2 z-10 inline-flex h-7 w-7 items-center justify-center rounded-md border border-transparent bg-slate-900/70 text-slate-300 transition-colors hover:bg-slate-800 hover:text-slate-100"
              data-install-copy-trigger
            >
              <span class="inline-flex" data-copy-icon><Copy class="h-3 w-3" /></span>
              <span class="hidden inline-flex" data-copied-icon><Check class="h-3 w-3 text-emerald-300" /></span>
            </button>
            <pre class="overflow-x-auto rounded-lg bg-slate-950 p-4 pr-12 text-sm text-slate-100"><code>curl -fsSL https://ai-colleagues.com/install.sh | sh</code></pre>
          </div>
          <div
            class="relative hidden"
            role="tabpanel"
            id="install-panel-windows"
            aria-labelledby="install-tab-windows"
            tabindex="0"
            hidden
            data-install-tab-panel
            data-tab-id="install-windows"
          >
            <button
              type="button"
              aria-label="Copy command"
              class="absolute right-2 top-2 z-10 inline-flex h-7 w-7 items-center justify-center rounded-md border border-transparent bg-slate-900/70 text-slate-300 transition-colors hover:bg-slate-800 hover:text-slate-100"
              data-install-copy-trigger
            >
              <span class="inline-flex" data-copy-icon><Copy class="h-3 w-3" /></span>
              <span class="hidden inline-flex" data-copied-icon><Check class="h-3 w-3 text-emerald-300" /></span>
            </button>
            <pre class="overflow-x-auto rounded-lg bg-slate-950 p-4 pr-12 text-sm text-slate-100"><code>irm https://ai-colleagues.com/install.ps1 | iex</code></pre>
          </div>
          <div
            class="relative hidden"
            role="tabpanel"
            id="install-panel-sdk"
            aria-labelledby="install-tab-sdk"
            tabindex="0"
            hidden
            data-install-tab-panel
            data-tab-id="install-sdk"
          >
            <button
              type="button"
              aria-label="Copy command"
              class="absolute right-2 top-2 z-10 inline-flex h-7 w-7 items-center justify-center rounded-md border border-transparent bg-slate-900/70 text-slate-300 transition-colors hover:bg-slate-800 hover:text-slate-100"
              data-install-copy-trigger
            >
              <span class="inline-flex" data-copy-icon><Copy class="h-3 w-3" /></span>
              <span class="hidden inline-flex" data-copied-icon><Check class="h-3 w-3 text-emerald-300" /></span>
            </button>
            <pre class="overflow-x-auto rounded-lg bg-slate-950 p-4 pr-12 text-sm text-slate-100"><code>uvx orcheo-sdk install</code></pre>
          </div>
          <div
            class="relative hidden"
            role="tabpanel"
            id="install-panel-upgrade"
            aria-labelledby="install-tab-upgrade"
            tabindex="0"
            hidden
            data-install-tab-panel
            data-tab-id="install-upgrade"
          >
            <button
              type="button"
              aria-label="Copy command"
              class="absolute right-2 top-2 z-10 inline-flex h-7 w-7 items-center justify-center rounded-md border border-transparent bg-slate-900/70 text-slate-300 transition-colors hover:bg-slate-800 hover:text-slate-100"
              data-install-copy-trigger
            >
              <span class="inline-flex" data-copy-icon><Copy class="h-3 w-3" /></span>
              <span class="hidden inline-flex" data-copied-icon><Check class="h-3 w-3 text-emerald-300" /></span>
            </button>
            <pre class="overflow-x-auto rounded-lg bg-slate-950 p-4 pr-12 text-sm text-slate-100"><code>orcheo install upgrade --yes</code></pre>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Features client:load />
  <section class="py-20 border-y bg-muted/20">
    <div class="container mx-auto px-4">
      <div class="text-center space-y-3 mb-12">
        <h2 class="text-3xl md:text-4xl font-bold">Latest Updates</h2>
        <p class="text-muted-foreground max-w-2xl mx-auto">
          Recent technical articles and company updates.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-6xl mx-auto">
        <div class={panelCardClass}>
          <div class="flex items-center justify-between gap-4 mb-5">
            <h3 class="text-2xl font-semibold">Blog</h3>
            <a
              href={withBase('/blog')}
              class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:gap-2 transition-all"
            >
              View all
              <ArrowRight class="h-4 w-4" />
            </a>
          </div>

          {latestBlogPosts.length === 0 ? (
            <p class="text-muted-foreground text-sm">No blog posts published yet.</p>
          ) : (
            <div class="space-y-4">
              {latestBlogPosts.map((post) => (
                <a
                  href={withBase(`/blog/${post.slug}`)}
                  class="group block rounded-xl border bg-background/50 p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-background/70 hover:shadow-[0_14px_30px_-20px_rgba(2,8,23,0.45)] dark:hover:shadow-[0_18px_36px_-22px_rgba(0,0,0,0.8)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
                >
                  <article>
                    <span class="inline-flex items-center gap-3 text-xs text-muted-foreground mb-2">
                      <span class="inline-flex items-center gap-1">
                        <Calendar class="h-3.5 w-3.5" />
                        {formatDate(post.data.pubDate)}
                      </span>
                      <span class="inline-flex items-center gap-1">
                        <Clock class="h-3.5 w-3.5" />
                        {estimateReadingTime(post.body).text}
                      </span>
                    </span>
                    <h4 class="font-semibold mb-1 transition-colors group-hover:text-primary">
                      {post.data.title}
                    </h4>
                    <p class="text-sm text-muted-foreground">{post.data.summary}</p>
                  </article>
                </a>
              ))}
            </div>
          )}
        </div>

        <div class={panelCardClass}>
          <div class="flex items-center justify-between gap-4 mb-5">
            <h3 class="text-2xl font-semibold">News</h3>
            <a
              href={withBase('/news')}
              class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:gap-2 transition-all"
            >
              View all
              <ArrowRight class="h-4 w-4" />
            </a>
          </div>

          {latestNewsPosts.length === 0 ? (
            <p class="text-muted-foreground text-sm">No news updates published yet.</p>
          ) : (
            <div class="space-y-4">
              {latestNewsPosts.map((post) => (
                <a
                  href={withBase(`/news/${post.slug}`)}
                  class="group block rounded-xl border bg-background/50 p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-background/70 hover:shadow-[0_14px_30px_-20px_rgba(2,8,23,0.45)] dark:hover:shadow-[0_18px_36px_-22px_rgba(0,0,0,0.8)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
                >
                  <article>
                    <span class="inline-flex items-center gap-1 text-xs text-muted-foreground mb-2">
                      <Calendar class="h-3.5 w-3.5" />
                      {formatDate(post.data.pubDate)}
                    </span>
                    <h4 class="font-semibold mb-1 transition-colors group-hover:text-primary">{post.data.title}</h4>
                    <p class="text-sm text-muted-foreground">{post.data.summary}</p>
                  </article>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
  <FAQ client:load />
</Layout>

<script>
  const installTabSections = document.querySelectorAll('[data-install-tabs]');
  for (const section of installTabSections) {
    const triggers = Array.from(
      section.querySelectorAll('[data-install-tab-trigger]'),
    ) as HTMLButtonElement[];
    const panels = Array.from(
      section.querySelectorAll('[data-install-tab-panel]'),
    ) as HTMLElement[];
    const copyTriggers = Array.from(
      section.querySelectorAll('[data-install-copy-trigger]'),
    ) as HTMLButtonElement[];

    const setActiveTab = (tabId: string) => {
      for (const trigger of triggers) {
        const isActive = trigger.dataset.tabId === tabId;
        trigger.setAttribute('aria-selected', isActive ? 'true' : 'false');
        trigger.setAttribute('tabindex', isActive ? '0' : '-1');
        trigger.classList.toggle('bg-muted', isActive);
      }

      for (const panel of panels) {
        const isActive = panel.dataset.tabId === tabId;
        panel.classList.toggle('hidden', !isActive);
        panel.toggleAttribute('hidden', !isActive);
      }
    };

    const moveFocus = (currentIndex: number, direction: number) => {
      const nextIndex = (currentIndex + direction + triggers.length) % triggers.length;
      const nextTrigger = triggers[nextIndex];
      const tabId = nextTrigger?.dataset.tabId;
      if (!nextTrigger || !tabId) return;
      setActiveTab(tabId);
      nextTrigger.focus();
    };

    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', () => {
        const tabId = trigger.dataset.tabId;
        if (tabId) {
          setActiveTab(tabId);
        }
      });

      trigger.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowRight') {
          event.preventDefault();
          moveFocus(index, 1);
        } else if (event.key === 'ArrowLeft') {
          event.preventDefault();
          moveFocus(index, -1);
        }
      });
    });

    for (const copyTrigger of copyTriggers) {
      let resetTimer: ReturnType<typeof setTimeout> | undefined;
      copyTrigger.addEventListener('click', async () => {
        const panel = copyTrigger.closest('[data-install-tab-panel]');
        const command = panel?.querySelector('code')?.textContent?.trim() ?? '';
        if (!command) return;

        const copyIcon = copyTrigger.querySelector('[data-copy-icon]');
        const copiedIcon = copyTrigger.querySelector('[data-copied-icon]');
        try {
          await navigator.clipboard.writeText(command);
          copyIcon?.classList.add('hidden');
          copiedIcon?.classList.remove('hidden');
        } catch (err) {
          console.warn('Clipboard write failed:', err);
          return;
        }

        if (resetTimer) {
          clearTimeout(resetTimer);
        }
        resetTimer = setTimeout(() => {
          copiedIcon?.classList.add('hidden');
          copyIcon?.classList.remove('hidden');
        }, 1000);
      });
    }

    const defaultTab = triggers[0]?.dataset.tabId;
    if (defaultTab) {
      setActiveTab(defaultTab);
    }
  }
</script>
